{
  "id": "breakbeat",
  "name": "BB Gen",
  "abbrev": "BB",
  "version": "0.1.2",
  "description": "Breakbeat generator with algorithmic retriggering",
  "author": "mestela",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "label": "Breakbeat Gen",
          "params": [
            {
              "key": "preset",
              "label": "Preset",
              "type": "int",
              "min": 0,
              "max": 10,
              "default": 0
            },
            {
              "key": "loop",
              "label": "Loop",
              "type": "enum",
              "options": [
                "action", "amen", "apache", "around", "boogiewoogie", "delight", "do", "eeloil", "fireeater", "funkydrummer", "groove", "hitormiss", "hotline", "hungup_0", "hungup_1", "impeach", "king", "kool", "marymary", "mechanicalman", "movement", "newday", "neworleans", "riffin", "rill", "ripple", "sesame", "sneakin", "sport", "squib", "swat", "think", "useme"
              ],
              "default": 0
            },
            {
              "key": "length",
              "label": "Length",
              "type": "enum",
              "options": [
                "0.25",
                "0.5",
                "1",
                "2",
                "4",
                "8"
              ],
              "default": 2
            },
            {
              "key": "complexity",
              "label": "Complexity",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 50
            },
            {
              "key": "retrigger",
              "label": "Retrigger",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger_rate",
              "label": "Retrig Rate",
              "type": "int",
              "min": 2,
              "max": 4,
              "default": 2
            }
          ],
          "knobs": [
            "preset",
            "loop",
            "length",
            "complexity",
            "retrigger",
            "retrigger_rate"
          ]
        }
      }
    }
  },
  "defaults": {
    "preset": 0
  }
}
