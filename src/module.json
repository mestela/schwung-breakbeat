{
  "id": "breakbeat",
  "name": "BB Gen",
  "abbrev": "BB",
  "version": "0.3.0",
  "description": "Breakbeat generator with algorithmic retriggering",
  "author": "mestela",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "label": "Breakbeat Gen",
          "params": [
            {
              "key": "preset",
              "label": "Preset",
              "type": "int",
              "min": 0,
              "max": 10,
              "default": 0
            },
            {
              "key": "sample_path",
              "label": "Sample",
              "type": "filepath",
              "root": "/data/UserData/breakbeat-samples",
              "filter": ".wav",
              "default": "/data/UserData/breakbeat-samples/Built-in/amen.wav"
            },
            {
              "key": "alt_sample_path",
              "label": "Alt Sample",
              "type": "filepath",
              "root": "/data/UserData/breakbeat-samples",
              "filter": ".wav",
              "default": "/data/UserData/breakbeat-samples/Built-in/amen09.wav"
            },
            {
              "key": "length",
              "label": "Length",
              "type": "enum",
              "options": [
                "0.25",
                "0.5",
                "1",
                "2",
                "4",
                "8"
              ],
              "default": 2
            },
            {
              "key": "complexity",
              "label": "Complexity",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 50
            },
            {
              "key": "anchor",
              "label": "Anchor",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "roll",
              "label": "Roll",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "phrase",
              "label": "Phrase",
              "type": "enum",
              "options": ["Off", "2 bars", "4 bars", "8 bars", "16 bars"],
              "default": 0
            },
            {
              "key": "fill",
              "label": "Fill",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger",
              "label": "Retrigger",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger_rate",
              "label": "Retrig Rate",
              "type": "enum",
              "options": ["2x", "3x", "4x", "8x", "Rand"],
              "default": 0
            },
            {
              "key": "swap_prob",
              "label": "Swap Prob",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            }
          ],
          "knobs": [
            "preset",
            "sample_path",
            "alt_sample_path",
            "length",
            "phrase",
            "complexity",
            "anchor",
            "roll",
            "fill",
            "retrigger",
            "retrigger_rate",
            "swap_prob"
          ]
        }
      }
    }
  },
  "defaults": {
    "preset": 0
  }
}
