{
  "id": "breakbeat",
  "name": "BB Gen",
  "abbrev": "BB",
  "version": "0.2.1",
  "description": "Breakbeat generator with algorithmic retriggering",
  "author": "mestela",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "label": "Breakbeat Gen",
          "params": [
            {
              "key": "preset",
              "label": "Preset",
              "type": "int",
              "min": 0,
              "max": 10,
              "default": 0
            },
            {
              "key": "loop",
              "label": "Loop",
              "type": "enum",
              "options": [
                "amen01", "amen09", "amen18", "amen19", "amen20", "apache", "do", "eeloil", "fireeater", "funkydrummer", "groove", "hungup_0", "king", "kool", "mechanicalman", "neworleans", "riffin", "ripple", "sesame", "sport", "squib", "think", "useme"
              ],
              "default": 0
            },
            {
              "key": "length",
              "label": "Length",
              "type": "enum",
              "options": [
                "0.25",
                "0.5",
                "1",
                "2",
                "4",
                "8"
              ],
              "default": 2
            },
            {
              "key": "complexity",
              "label": "Complexity",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 50
            },
            {
              "key": "anchor",
              "label": "Anchor",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "roll",
              "label": "Roll",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "phrase",
              "label": "Phrase",
              "type": "enum",
              "options": ["Off", "2", "4", "8", "16"],
              "default": 0
            },
            {
              "key": "fill",
              "label": "Fill",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger",
              "label": "Retrigger",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger_rate",
              "label": "Retrig Rate",
              "type": "enum",
              "options": ["2x", "3x", "4x", "8x", "Rand"],
              "default": 0
            }
          ],
          "knobs": [
            "preset",
            "loop",
            "length",
            "phrase",
            "complexity",
            "anchor",
            "roll",
            "fill",
            "retrigger",
            "retrigger_rate"
          ]
        }
      }
    }
  },
  "defaults": {
    "preset": 0
  }
}
