{
  "id": "breakbeat",
  "name": "Breakbeat",
  "abbrev": "BB",
  "version": "0.3.3",
  "description": "Breakbeat generator with algorithmic retriggering",
  "author": "mestela",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "label": "Breakbeat Gen",
          "params": [
            {
              "key": "preset",
              "label": "Preset",
              "type": "int",
              "min": 0,
              "max": 10,
              "default": 0
            },
            {
              "key": "A_sample_path",
              "label": "A Sample",
              "type": "filepath",
              "root": "/data/UserData/breakbeat-samples",
              "filter": ".wav",
              "default": "/data/UserData/breakbeat-samples/Built-in/amen.wav"
            },
            {
              "key": "A_sample_length",
              "label": "A Length",
              "type": "enum",
              "options": [
                "1/4 bar", "1/2 bar", "1 bar", "2 bars", "4 bars", "8 bars"
              ],
              "default": 2
            },
            {
              "key": "B_sample_path",
              "label": "B Sample",
              "type": "filepath",
              "root": "/data/UserData/breakbeat-samples",
              "filter": ".wav",
              "default": "/data/UserData/breakbeat-samples/Built-in/amen09.wav"
            },
            {
              "key": "B_sample_length",
              "label": "B Length",
              "type": "enum",
              "options": [
                "1/4 bar", "1/2 bar", "1 bar", "2 bars", "4 bars", "8 bars"
              ],
              "default": 2
            },
            {
              "key": "B_chance",
              "label": "B Chance",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "complexity",
              "label": "Complexity",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 50
            },
            {
              "key": "phrase",
              "label": "Phrase",
              "type": "enum",
              "options": ["Off", "2 bars", "4 bars", "8 bars", "16 bars"],
              "default": 0
            },
            {
              "key": "anchor",
              "label": "Anchor",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "roll",
              "label": "Roll",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "fill",
              "label": "Fill",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger",
              "label": "Retrigger",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0
            },
            {
              "key": "retrigger_rate",
              "label": "Retrig Rate",
              "type": "enum",
              "options": ["2x", "3x", "4x", "8x", "Rand"],
              "default": 0
            },
            {
              "key": "save_preset",
              "label": "Save Preset",
              "type": "int",
              "min": 0,
              "max": 1,
              "default": 0
            },
            {
              "key": "status",
              "label": "Status",
              "type": "enum",
              "options": ["-"],
              "default": 0
            }
          ],
          "knobs": [
            "preset",
            "A_sample_path",
            "A_sample_length",
            "B_sample_path",
            "B_sample_length",
            "B_chance",
            "complexity",
            "phrase",
            "anchor",
            "roll",
            "fill",
            "retrigger",
            "retrigger_rate",
            "save_preset",
            "status"
          ]
        }
      }
    }
  },
  "defaults": {
    "preset": 0
  }
}
